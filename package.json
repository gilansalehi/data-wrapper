{
  "name": "data-wrapper",
  "version": "0.1.0",
  "description": "Zero-dependency HTML-first reactivity engine built on native Web Components",
  "type": "module",
  "main": "./dist/data-wrapper.js",
  "module": "./dist/data-wrapper.js",
  "exports": {
    ".": {
      "import": "./dist/data-wrapper.js",
      "default": "./dist/data-wrapper.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/lib/index.ts --outfile ./dist/data-wrapper.js --format esm --target browser && bun build ./src/lib/index.ts --outfile ./dist/data-wrapper.min.js --format iife --minify --target browser",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "serve": "bun serve.ts"
  },
  "keywords": ["web-components", "data-binding", "reactivity", "no-build", "html-first", "framework"],
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "latest",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
